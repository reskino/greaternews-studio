# Copy this file to `.env` for local dev. For the DEPLOYED app, set the same names
# as GitHub repo secrets (Settings -> Secrets and variables -> Actions) — the deploy
# workflow injects them at build time.

# Optional: Claude-powered photo-search query understanding directly in the browser
# (when scripts/resolver.py isn't running). A VITE_ var is embedded in the built bundle.
VITE_ANTHROPIC_API_KEY=

# Google Programmable Search — broad web image results ("millions of images").
# Setup (all free):
#   1. Create a Programmable Search Engine at https://programmablesearchengine.google.com
#      - "Search the entire web" ON, "Image search" ON. Copy the Search engine ID -> VITE_GOOGLE_CSE_CX
#   2. Get an API key at https://console.cloud.google.com (enable "Custom Search API").
#      RESTRICT the key: HTTP referrers = https://reskino.github.io/* (and http://localhost:*
#      for local dev), API restriction = Custom Search API only. Then it is safe in the bundle.
#      Put it in VITE_GOOGLE_CSE_KEY.
# Free tier: 100 image searches/day.
VITE_GOOGLE_CSE_KEY=
VITE_GOOGLE_CSE_CX=

# Serper.dev — real Google Images, the simplest broad-image source (no Cloud project / CSE).
# Sign up at https://serper.dev (free ~2,500 searches), copy the API key here.
# Note: Serper keys can't be domain-restricted, so this key is visible in the built bundle.
# Fine for a personal tool; rotate it at serper.dev if the free quota ever gets abused.
VITE_SERPER_API_KEY=
