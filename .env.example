# Optional: enables the Claude-powered photo search DIRECTLY in the browser when the
# local resolver (scripts/resolver.py) isn't running. Copy this file to `.env`.
#
# WARNING: a VITE_ variable is embedded in the built JS bundle, so anyone who loads
# the studio can read it. Use this ONLY for a personal/local build you don't deploy
# publicly. For a hosted studio, run scripts/resolver.py instead (key stays server-side).
VITE_ANTHROPIC_API_KEY=
