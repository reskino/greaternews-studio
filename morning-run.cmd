@echo off
rem GreaterNews morning run - scheduled daily. Writes today's verified content pack
rem AND auto-renders the finished card PNGs + videos into content\<date>\assets\.
cd /d C:\GreaterNews
echo ===== GreaterNews morning run started %date% %time% ===== >> C:\GreaterNews\content\morning-run.log
echo ----- refreshing local build ----- >> C:\GreaterNews\content\morning-run.log
call npm run build >> C:\GreaterNews\content\morning-run.log 2>&1
if errorlevel 1 echo build failed - continuing with existing dist >> C:\GreaterNews\content\morning-run.log
claude -p "Read C:\GreaterNews\GreaterNews_Master_Prompt.md and follow it strictly as the GreaterNews content engine. Do the Daily run now. Search the web for todays top stories in each bucket: Ghana politics 1-2, Ghana business 1, sports 1-2, entertainment 1, world 1-2, tech optional. Verify every story with two or more independent current sources and label single-source stories DEVELOPING. Check the files in C:\GreaterNews\content and posted_log.md first so no story repeats. Then write the story menu plus complete content packs for the top 5 stories in all output formats to a new file named C:\GreaterNews\content\greaternews_DATE.md where DATE is todays date in YYYY-MM-DD format. Include the source URLs you verified against. ALSO write a card spec file C:\GreaterNews\content\cards_DATE.json with this exact JSON shape: {\"date\":\"DATE\",\"cards\":[{\"slug\":\"kebab-case-story-slug\",\"template\":\"headline or quote or update or stat\",\"headline\":\"card headline max 9 words (for quote: the exact quote under 15 words; for stat: the label)\",\"subline\":\"one sentence of context under the headline (headline and update templates, else empty)\",\"highlight\":\"2-4 headline words to color, empty string for tragedy\",\"attribution\":\"speaker name and title (quote template only, else empty)\",\"chip\":\"UPDATE or DEVELOPING or BREAKING (update template only)\",\"statValue\":\"the number (stat template only, else empty)\",\"footer\":\"Source: X / Y\",\"dim\":0.3 to 0.6 higher for somber stories,\"formats\":[\"portrait\"],\"video\":true for the top story and stat cards else false,\"photoUrl\":null,\"articleUrl\":\"the lead source article URL for Ghana-outlet stories, else null\",\"photoQuery\":\"the safe entity or place to depict, e.g. Bank of Ghana or Carlos Queiroz or Accra skyline\",\"scenes\":[\"for cards with video:true, 4 to 6 SHORT on-screen captions in order, each prefixed with an ALL-CAPS [SECTION] label like [THE STORY] [THE DETAIL] [WHY IT MATTERS] [WHAT'S NEXT], max 6 words each, NOT full sentences. Empty array [] for cards without video\"],\"narration\":[\"one FULLER spoken sentence per scene (~18-28 words), SAME ORDER as scenes, that the voiceover reads to actually tell the story; drawn only from verified facts, no hashtags. Empty [] for cards without video\"],\"photoQueries\":[\"one concrete licensed-photo subject per scene to depict (a person, place, building or thing), Ghana-aware, SAME ORDER as scenes; empty string for a scene with nothing safe to depict. Empty [] for cards without video\"],\"sound\":\"background music for video cards: newsroom for politics/business/hard news, uplift for sports/entertainment/positive stories, calm for somber or tragic stories; none for cards without video\",\"voice\":\"groq for cards with video:true (the free Groq voiceover reads the narration), else none\"}]}. Use photoUrl ONLY for an image we verifiably hold rights to. articleUrl makes the renderer use that article's own image credited to the outlet - set it for Ghana outlet stories, but set it to null for world/agency stories where photos are usually AFP or Getty or Reuters, and null for tragedy, crime, victims or private individuals. photoQuery is the licensed Wikipedia/Commons fallback with automatic credit - the named organisation, public figure, venue or place; null for sensitive stories. ALSO write a publish queue C:\GreaterNews\content\queue_DATE.json with this exact shape: {\"date\":\"DATE\",\"items\":[{\"platform\":\"facebook or x\",\"status\":\"pending\",\"image\":\"DATE/assets/SLUG_4x5.png or null\",\"text\":\"the full post text for that platform from the pack\"}]} ordered strongest story first, with a facebook and an x item for each of the top 3 stories (X posts must be 280 characters or fewer). Do not post anything anywhere yourself. End the pack file with a list of any DEVELOPING stories that need follow-up." --allowedTools "Read,Write,Glob,Grep,WebSearch,WebFetch" >> C:\GreaterNews\content\morning-run.log 2>&1
echo ----- starting local resolver (TTS for voiceover) ----- >> C:\GreaterNews\content\morning-run.log
start "" /B cmd /c "python C:\GreaterNews\scripts\resolver.py >> C:\GreaterNews\content\resolver.log 2>&1"
timeout /t 3 /nobreak >nul
echo ----- rendering card assets ----- >> C:\GreaterNews\content\morning-run.log
python C:\GreaterNews\scripts\render_assets.py >> C:\GreaterNews\content\morning-run.log 2>&1
echo ----- stopping local resolver ----- >> C:\GreaterNews\content\morning-run.log
powershell -NoProfile -Command "Get-NetTCPConnection -LocalPort 5199 -State Listen -ErrorAction SilentlyContinue | Select-Object -Expand OwningProcess -Unique | ForEach-Object { Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue }" >> C:\GreaterNews\content\morning-run.log 2>&1
echo ----- publish queue status ----- >> C:\GreaterNews\content\morning-run.log
python C:\GreaterNews\scripts\publish.py --dry-run >> C:\GreaterNews\content\morning-run.log 2>&1
echo ===== GreaterNews morning run finished %date% %time% ===== >> C:\GreaterNews\content\morning-run.log
